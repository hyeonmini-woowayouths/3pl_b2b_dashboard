# === Server ===
PORT=3001

# === Auth ===
# development = X-Dev-User 헤더 또는 기본 운영자 (인증 생략)
# production = JWT Bearer Token (사내 IAM 연동)
AUTH_MODE=development

# === n8n Webhook URLs ===
# 보안 제안서 발송 (이메일 + 인증코드 생성)
N8N_WEBHOOK_PROPOSAL=https://n8n.internal.example.com/webhook/3pl-proposal-send
# 서류 보완 알림톡 (카카오 BIZ_DOC_RESUBMIT)
N8N_WEBHOOK_DOC_REMIND=https://n8n.internal.example.com/webhook/3pl-doc-remind
# Google Drive 폴더 생성 + 파일 리네임/업로드
N8N_WEBHOOK_DRIVE_UPLOAD=https://n8n.internal.example.com/webhook/3pl-drive-upload
# Slack 알림 (계약 체결, 서류 반려 등 이벤트)
N8N_WEBHOOK_SLACK_NOTIFY=https://n8n.internal.example.com/webhook/3pl-slack-notify
# OCR 파싱 (Bedrock Vision — 사업자등록증 이미지 → JSON)
N8N_WEBHOOK_OCR_PARSE=https://n8n.internal.example.com/webhook/3pl-ocr-parse

# === 싸인오케이 API ===
SIGNOK_API_URL=https://api.signok.com/v1
SIGNOK_API_KEY=sk_test_dummy_key_replace_me
SIGNOK_SENDER_EMAIL=3pl-ops@woowayouths.com

# === Google Drive ===
GDRIVE_ROOT_FOLDER_ID=1ABC_dummy_folder_id

# === Feature Flags ===
# true = 실제 API 호출, false = 로깅만 (개발 모드)
EXTERNAL_API_LIVE=false
